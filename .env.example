# Hireloop environment template
#
# The client app reads its values from client/.env.local.
# The server app reads its values from server/.env.

# Shared MongoDB connection string
MONGO_DB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/hireloop

# Server
PORT=5000

# Client API/auth URLs
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Better Auth / OAuth
BETTER_AUTH_SECRET=replace-with-a-secure-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Uploads
IMGBB_API_KEY=
